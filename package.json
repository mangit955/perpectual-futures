{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "diag": "cd apps/api && bun run diag.ts",
    "diag:full": "bun run scripts/detailed-diag.ts",
    "cleanup:pel": "bun run scripts/cleanup-pel.ts",
    "reset:consumers": "bun run scripts/reset-consumer-group.ts",
    "monitor": "bun run scripts/monitor-production.ts",
    "test:cancel": "bun run scripts/test-cancel-flow.ts",
    "test:redis": "bun run scripts/test-redis-connection.ts",
    "test:production": "bun run scripts/test-production-order.ts",
    "init:redis": "bun run scripts/init-redis-groups.ts",
    "verify:db": "bun run scripts/verify-db.ts",
    "check:redis": "bun run scripts/check-redis-streams.ts",
    "claim:pending": "bun run scripts/claim-pending-messages.ts",
    "test:workers": "bun run scripts/test-workers-local.ts",
    "debug:streams": "bun run scripts/debug-stream-messages.ts"
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "ioredis": "^5.11.1",
    "prettier": "^3.7.4",
    "prisma": "6.19.3",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
